generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum LanguageLevel {
	BEGINNER
	ELEMENTARY
	INTERMEDIATE
	UPPER_INTERMEDIATE
	ADVANCED
	PROFICIENT
}

enum LearningGoal {
	TRAVEL
	WORK
	SCHOOL
	EXAM
	HOBBY
	OTHER
}

enum DifficultyLevel {
	EASY
	MEDIUM
	HARD
}

enum QuestionType {
	SINGLE_CHOICE
	MULTIPLE_CHOICE
	TRUE_FALSE
	OPEN
}

model User {
	id                Int       @id @default(autoincrement())

	username          String    @unique
	email             String    @unique
	password          String

	firstName         String?
	lastName          String?
	phone             String?

	createdAt         DateTime  @default(now())
	updatedAt         DateTime? @updatedAt
	lastLogin         DateTime?

	learningProfiles  LearningProfile[]
	flashcardSets     FlashcardSet[]
	quizzes           Quiz[]
	quizResults       QuizResult[]

	@@map("users")
}

model LearningProfile {
	id                Int            @id @default(autoincrement())

	userId            Int
	targetLanguage    String
	level             LanguageLevel?
	goal              LearningGoal?

	createdAt         DateTime       @default(now())
	updatedAt         DateTime?      @updatedAt

	user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@map("learning_profiles")
}

model FlashcardSet {
	id                Int                @id @default(autoincrement())

	userId            Int

	name              String
	description       String?

	category          String?
	language          String?

	difficultyLevel   DifficultyLevel?

	createdAt         DateTime           @default(now())
	updatedAt         DateTime?          @updatedAt

	user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

	flashcards        Flashcard[]

	@@map("flashcard_sets")
}

model Flashcard {
	id                Int                @id @default(autoincrement())

	flashcardSetId    Int

	question          String
	answer            String

	type              String?
	explanation       String?

	difficultyLevel   DifficultyLevel?

	createdAt         DateTime           @default(now())
	updatedAt         DateTime?          @updatedAt

	flashcardSet      FlashcardSet       @relation(fields: [flashcardSetId], references: [id], onDelete: Cascade)

	@@map("flashcards")
}

model Quiz {
	id                Int                @id @default(autoincrement())

	userId            Int

	name              String
	description       String?

	questionCount     Int                @default(0)

	createdAt         DateTime           @default(now())
	updatedAt         DateTime?          @updatedAt

	user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

	questions         QuizQuestion[]
	results           QuizResult[]

	@@map("quizzes")
}

model QuizQuestion {
	id                Int                @id @default(autoincrement())

	quizId            Int

	type              QuestionType?
	content           String

	difficultyLevel   DifficultyLevel?

	createdAt         DateTime           @default(now())

	quiz              Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)

	answers           QuizAnswer[]

	@@map("quiz_questions")
}

model QuizAnswer {
	id                Int                @id @default(autoincrement())

	questionId        Int

	content           String

	isCorrect         Boolean            @default(false)

	question          QuizQuestion       @relation(fields: [questionId], references: [id], onDelete: Cascade)

	@@map("quiz_answers")
}

model QuizResult {
	id                Int                @id @default(autoincrement())

	quizId            Int
	userId            Int

	correctAnswers    Int                @default(0)
	incorrectAnswers  Int                @default(0)

	percentageScore   Float?

	completedAt       DateTime           @default(now())

	quiz              Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)

	user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@map("quiz_results")
}