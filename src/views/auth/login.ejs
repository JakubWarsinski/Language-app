<!DOCTYPE html>
<html>
  <head>
    <title>Login</title>
  </head>

  <body>
    <div class="box">
      <h2>Login</h2>

      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form method="POST" action="login">
        <input
          type="email"
          name="email"
          placeholder="Email"
          required
        />

        <input
          type="password"
          name="password"
          placeholder="Password"
          required
        />

        <button type="submit">Login</button>
      </form>
    </div>
  </body>
</html>